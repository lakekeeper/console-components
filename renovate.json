{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["before 9am on monday"],
  "packageRules": [
    {
      "groupName": "eslint",
      "matchPackageNames": ["/eslint/", "/typescript-eslint/", "/vue-eslint-parser/", "/globals/"]
    },
    {
      "groupName": "vue ecosystem",
      "matchPackageNames": ["/vue/", "/vuetify/", "/pinia/", "/vue-router/", "/vue-tsc/"]
    },
    {
      "groupName": "vite",
      "matchPackageNames": ["/vite/", "/@vitejs/"]
    },
    {
      "groupName": "codemirror",
      "matchPackageNames": ["/@codemirror/", "/@lezer/", "/codemirror/"]
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true
    },
    {
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}
