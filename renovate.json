{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["before 9am on monday"],
  "packageRules": [
    {
      "groupName": "eslint",
      "matchPackagePatterns": ["eslint", "typescript-eslint", "vue-eslint-parser", "globals"]
    },
    {
      "groupName": "vue ecosystem",
      "matchPackagePatterns": ["vue", "vuetify", "pinia", "vue-router", "vue-tsc"]
    },
    {
      "groupName": "vite",
      "matchPackagePatterns": ["vite", "@vitejs"]
    },
    {
      "groupName": "codemirror",
      "matchPackagePatterns": ["@codemirror", "@lezer", "codemirror"]
    },
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true
    }
  ]
}
